{
  "name": "faculty-management-backend",
  "version": "1.0.0",
  "description": "Backend for Faculty Student Management System",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/backend/src/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/migrate.ts",
    "seed-admin": "tsx src/seed-admin.ts",
    "seed-example": "tsx src/seed-example-data.ts",
    "test": "vitest run --config vitest.config.mts",
    "test:db": "vitest run --config vitest.db.config.mts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.5",
    "@types/pg": "^8.10.2",
    "tsx": "^4.22.3",
    "typescript": "^5.1.6",
    "vitest": "^2.1.8"
  }
}
