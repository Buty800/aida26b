{
  "name": "faculty-management-frontend",
  "version": "1.0.0",
  "description": "Frontend for Faculty Student Management System",
  "type": "module",
  "scripts": {
    "build": "tsc && node ./copy-static.cjs",
    "start": "http-server dist -p 8080",
    "dev": "tsc --watch & http-server src -p 8080",
    "e2e": "playwright test -c e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.1",
    "http-server": "^14.1.1",
    "typescript": "^5.1.6"
  }
}
