{
  "name": "faculty-management-frontend",
  "version": "1.0.0",
  "description": "Frontend for Faculty Student Management System",
  "type": "module",
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test -c e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.1",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "jsdom": "^25.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4",
    "webpack-merge": "^6.0.1"
  }
}
