# Example environment variables for running docker-compose
# Copy to .env and edit values before running compose

# Docker / app
NODE_ENV=development
PORT=3000

# Database used by the app (postgres service)
DB_HOST=database
DB_PORT=5432
DB_NAME=faculty_management
DB_USER=aida26_user
DB_PASSWORD=CambiaEsta!

# Admin DB user — used for tracker operations and generic CRUD
ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=AdminPass123!

# Auth DB user — used for login, sessions, password changes
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=AuthPass123!

# Postgres initialization (superuser used only for bootstrap in container)
POSTGRES_SUPERUSER=aida26_user
POSTGRES_SUPERPASS=CambiaEsta!
POSTGRES_DB_NAME=faculty_management


ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
ADMIN_EMAIL=admin@example.com